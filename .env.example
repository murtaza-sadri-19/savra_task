# API Configuration
# Add your Groq API key here: https://console.groq.com/
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxx

# Model Configuration
FAST_MODEL=llama-3.1-8b-instant
SMART_MODEL=llama-3.3-70b-versatile

# LLM Parameters
TEMPERATURE=0.4
MAX_TOKENS=4096
AVG_TOKENS=5000

# Retry Configuration
MAX_RETRIES=3
RETRY_DELAYS=1,3,7

# Cache Configuration
CACHE_TTL_HOURS=8

# Pricing Configuration (USD per 1M tokens)
FAST_MODEL_COST_USD=0.05
SMART_MODEL_COST_USD=0.59
INR_PER_USD=83.5
CACHE_SAVINGS_INR=15.0

# CORS Configuration
# For production, replace * with specific origins: https://app.example.com,https://admin.example.com
CORS_ALLOW_ORIGINS=*

# Logging Configuration
LOG_LEVEL=INFO
LOG_MODULE=savra

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_RELOAD=true

# Application Configuration
APP_TITLE=Savra PPT Generator
APP_VERSION=0.1.0
